generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // DIRECT_URL bypasses PgBouncer for migrations / prisma db push / introspection.
  // Transaction-mode PgBouncer can't hold the long-lived DDL transactions those
  // tools need, so they need a direct connection. Falls back to DATABASE_URL
  // when DIRECT_URL isn't set (e.g. local dev without a pooler).
  directUrl = env("DIRECT_URL")
}

model Supplier {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  code        String   @unique
  adapterType String   @map("adapter_type")
  baseUrl     String   @map("base_url")
  credentials String   @default("{}")
  priority    Int      @default(100)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  brandRules  SupplierBrandRule[]
  productMaps ProductMap[]
  overrides   Override[]
  matchLogs   MatchLog[]
  unmatched   Unmatched[]
  uploads     SupplierUpload[]

  @@index([active, priority])
  @@map("suppliers")
}

model Brand {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  code             String   @unique
  tecdocId         Int?     @unique @map("tecdoc_id")
  logoUrl          String?  @map("logo_url")
  showOnStorefront Boolean  @default(false) @map("show_on_storefront")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  brandRules  SupplierBrandRule[]
  productMaps ProductMap[]
  overrides   Override[]
  matchLogs   MatchLog[]
  unmatched   Unmatched[]

  @@map("brands")
}

model StockLocation {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  country   String   @default("NL")
  address   String?
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  productStocks ProductStock[]

  @@map("stock_locations")
}

model ProductStock {
  id           Int      @id @default(autoincrement())
  productMapId Int      @map("product_map_id")
  locationId   Int      @map("location_id")
  quantity     Int      @default(0)
  updatedAt    DateTime @updatedAt @map("updated_at")

  productMap ProductMap    @relation(fields: [productMapId], references: [id], onDelete: Cascade)
  location   StockLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([productMapId, locationId])
  @@index([locationId])
  @@map("product_stock")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  tecdocId    Int?     @unique @map("tecdoc_id")
  parentId    Int?     @map("parent_id")
  level       Int      @default(0)
  position       Int      @default(0)
  description    String?
  seoDescription String?  @map("seo_description")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent   Category?    @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[]   @relation("CategoryTree")
  products ProductMap[]

  @@index([parentId])
  @@index([parentId, position])
  @@map("categories")
}

model SupplierBrandRule {
  id             Int      @id @default(autoincrement())
  supplierId     Int      @map("supplier_id")
  brandId        Int      @map("brand_id")
  supplierBrand  String   @map("supplier_brand")
  prefixStrip    String?  @map("prefix_strip")
  suffixStrip    String?  @map("suffix_strip")
  normalizeRegex String?  @map("normalize_regex")
  matchOrder     Json?    @map("match_order")
  priority       Int      @default(100)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([supplierId, supplierBrand])
  @@index([supplierId, brandId])
  @@map("supplier_brand_rules")
}

model ProductMap {
  id             Int       @id @default(autoincrement())
  supplierId     Int       @map("supplier_id")
  brandId        Int       @map("brand_id")
  categoryId     Int?      @map("category_id")
  sku            String
  articleNo      String    @map("article_no")
  ean            String?
  tecdocId       String?   @map("tecdoc_id")
  oem            String?
  description    String    @default("")
  imageUrl       String?   @map("image_url")
  images         Json?     @default("[]")
  price          Float?
  currency       String?   @default("EUR")
  stock          Int?
  weight         Float?
  genericArticle String?   @map("generic_article")
  oemNumbers     Json?     @default("[]") @map("oem_numbers")
  icSku          String?   @map("ic_sku")
  icMatchedAt    DateTime? @map("ic_matched_at")
  articleCriteria Json?    @default("[]") @map("article_criteria")
  status         String    @default("active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  supplier Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  brand    Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category   Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  stockByLoc ProductStock[]

  @@unique([supplierId, sku])
  @@index([supplierId, ean])
  @@index([supplierId, tecdocId])
  @@index([supplierId, brandId, articleNo])
  @@index([categoryId])
  @@index([ean])
  @@index([tecdocId])
  @@index([oem])
  @@index([articleNo])
  @@index([createdAt])
  @@index([icSku])
  @@map("product_maps")
}

model Override {
  id         Int      @id @default(autoincrement())
  supplierId Int      @map("supplier_id")
  brandId    Int      @map("brand_id")
  articleNo  String   @map("article_no")
  sku        String
  ean        String?
  tecdocId   String?  @map("tecdoc_id")
  oem        String?
  reason     String   @default("")
  createdBy  String   @map("created_by")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([supplierId, brandId, articleNo])
  @@index([supplierId, ean])
  @@index([supplierId, tecdocId])
  @@index([createdAt])
  @@map("overrides")
}

model MatchLog {
  id         Int      @id @default(autoincrement())
  supplierId Int      @map("supplier_id")
  brandId    Int?     @map("brand_id")
  query      String
  sku        String?
  method     String?
  confidence Float?
  matched    Boolean
  durationMs Int      @map("duration_ms")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  brand    Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)

  @@index([supplierId, createdAt])
  @@index([matched, createdAt])
  @@index([method, createdAt])
  @@index([createdAt])
  @@map("match_logs")
}

model IntercarsMapping {
  id            Int      @id @default(autoincrement())
  towKod        String   @map("tow_kod")
  icIndex       String   @map("ic_index")
  articleNumber String   @map("article_number")
  manufacturer  String
  tecdocProd    Int?     @map("tecdoc_prod")
  description   String   @default("")
  ean           String?
  weight        Float?
  blockedReturn Boolean  @default(false) @map("blocked_return")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([towKod])
  @@index([manufacturer, articleNumber])
  @@index([articleNumber])
  @@index([ean])
  @@map("intercars_mappings")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model Unmatched {
  id         Int       @id @default(autoincrement())
  supplierId Int       @map("supplier_id")
  brandId    Int?      @map("brand_id")
  query      String
  articleNo  String?   @map("article_no")
  ean        String?
  tecdocId   String?   @map("tecdoc_id")
  oem        String?
  attempts   Int       @default(1)
  resolvedAt DateTime? @map("resolved_at")
  resolvedBy String?   @map("resolved_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  brand    Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)

  @@unique([supplierId, query])
  @@index([resolvedAt])
  @@index([createdAt])
  @@index([attempts])
  @@map("unmatched")
}

model SupplierUpload {
  id          Int       @id @default(autoincrement())
  supplierId  Int       @map("supplier_id")
  fileType    String    @map("file_type") // pricing, stock, product_info, catalog
  fileName    String    @map("file_name")
  minioKey    String    @map("minio_key")
  fileSize    Int       @map("file_size")
  rowCount    Int?      @map("row_count")
  status      String    @default("uploaded") // uploaded, processing, completed, failed
  result      Json?     // {imported, updated, errors, duration}
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId, fileType])
  @@index([createdAt])
  @@map("supplier_uploads")
}

model Order {
  id           Int      @id @default(autoincrement())
  cartKey      String?  @map("cart_key")
  wcOrderId    Int?     @map("wc_order_id")
  wcOrderUrl   String?  @map("wc_order_url")
  status       String   @default("pending") // pending, processing, completed, cancelled, failed
  total        Float
  currency     String   @default("EUR")
  customerEmail String  @map("customer_email")
  customerName  String  @map("customer_name")
  customerPhone String? @map("customer_phone")
  shipping     Json     // {street, city, postcode, country}
  items        Json     // [{articleNo, name, sku, brand, price, quantity}]
  note         String?
  errorMessage String?  @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([customerEmail])
  @@index([wcOrderId])
  @@index([createdAt])
  @@map("orders")
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  type        String   @default("TASK")
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  assignee    String?
  reporter    String?
  labels      String[] @default([])
  relatedUrl  String?  @map("related_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([type])
  @@index([assignee])
  @@index([createdAt])
  @@map("tasks")
}
