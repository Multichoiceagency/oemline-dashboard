# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
API_KEY=your-api-key

# Database
DATABASE_URL=postgresql://oemline:oemline_secret@localhost:5432/oemline?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Meilisearch
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=your-meili-key

# TecDoc
TECDOC_API_KEY=your-tecdoc-key
TECDOC_API_URL=https://webservice.tecalliance.services/pegasus-3-0/services/TecdocToCatDLB.jsonEndpoint

# InterCars
INTERCARS_TOKEN_URL=https://is.webapi.intercars.eu/oauth2/token
INTERCARS_API_URL=https://api.webapi.intercars.eu/ic
INTERCARS_CLIENT_ID=
INTERCARS_CLIENT_SECRET=
INTERCARS_CUSTOMER_ID=
INTERCARS_PAYER_ID=
INTERCARS_BRANCH=

# MinIO / S3 Object Storage
MINIO_ENDPOINT=minio.oemline.eu
MINIO_PORT=443
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=oemline
MINIO_PUBLIC_URL=https://minio.oemline.eu
